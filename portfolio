<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TradeArena • Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', system_ui, sans-serif;
        }
        
        .dashboard-bg {
            background: linear-gradient(180deg, #0f172a 0%, #020617 100%);
        }
        
        .card-hover {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .card-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgb(16 185 129 / 0.1);
        }
        
        .live-dot {
            animation: pulse 2s infinite;
        }
    </style>
</head>
<body class="dashboard-bg text-white min-h-screen">

    <!-- TOP NAV (same as trade.html) -->
    <nav class="bg-slate-900 border-b border-slate-700 px-6 py-3 flex items-center justify-between sticky top-0 z-50">
        <div class="flex items-center gap-8">
            <!-- Logo -->
            <div class="flex items-center gap-2">
                <div class="w-9 h-9 bg-emerald-500 rounded-2xl flex items-center justify-center text-2xl font-bold">₿</div>
                <h1 class="text-3xl font-bold tracking-tighter">TradeArena</h1>
            </div>

            <!-- Market Selector -->
            <div class="flex items-center gap-2 bg-slate-800 rounded-3xl px-5 py-2 text-sm font-medium">
                <div class="flex items-center gap-1.5">
                    <span class="text-emerald-400">🇦🇺</span>
                    <span>ASX</span>
                </div>
                <i class="fa-solid fa-chevron-down text-xs"></i>
                <div onclick="switchMarket()" class="cursor-pointer hover:text-white px-3 py-1 rounded-3xl transition">🇺🇸 US</div>
            </div>

            <!-- Search -->
            <div class="relative w-96">
                <input type="text" placeholder="Search your holdings... (BHP, CBA...)" 
                       class="w-full bg-slate-800 text-white placeholder:text-slate-400 border border-slate-700 focus:border-emerald-500 rounded-3xl pl-12 pr-6 py-3 text-sm outline-none">
                <i class="fa-solid fa-magnifying-glass absolute left-5 top-1/2 -translate-y-1/2 text-slate-400"></i>
            </div>
        </div>

        <div class="flex items-center gap-8">
            <!-- Portfolio Stats -->
            <div class="flex items-center gap-6">
                <div>
                    <div class="text-xs text-slate-400">Portfolio Value</div>
                    <div id="total-value" class="text-3xl font-semibold text-emerald-400">$48,742.80</div>
                </div>
                <div class="text-right">
                    <div class="text-xs text-slate-400">Total P&amp;L</div>
                    <div id="total-pl" class="flex items-center gap-1 text-2xl font-semibold text-emerald-400">
                        +$4,872.30 <span class="text-emerald-400 text-base">(+11.1%)</span>
                    </div>
                </div>
                <div class="text-right">
                    <div class="text-xs text-slate-400">Today's P&amp;L</div>
                    <div id="today-pl" class="flex items-center gap-1 text-lg font-semibold text-emerald-400">
                        +$1,284.50 <span class="text-emerald-400 text-sm">(+2.71%)</span>
                    </div>
                </div>
            </div>

            <!-- User -->
            <div class="flex items-center gap-3">
                <div class="text-right">
                    <div class="font-semibold">Alex Chen</div>
                    <div class="text-xs text-slate-400">@tradearena07 • Paper Mode</div>
                </div>
                <div class="w-9 h-9 bg-gradient-to-br from-purple-500 to-emerald-500 rounded-2xl flex items-center justify-center text-xl">👨‍💼</div>
            </div>
        </div>
    </nav>

    <div class="flex h-[calc(100vh-65px)]">

        <!-- LEFT SIDEBAR (same as trade.html) -->
        <div class="w-64 bg-slate-900 border-r border-slate-700 p-4 flex flex-col">
            <nav class="space-y-1">
                <a onclick="navigateTo('dashboard')" class="flex items-center gap-3 px-4 py-4 hover:bg-slate-800 rounded-3xl transition">
                    <i class="fa-solid fa-chart-line w-5"></i>
                    <span>Dashboard</span>
                </a>
                <a onclick="navigateTo('markets')" class="flex items-center gap-3 px-4 py-4 hover:bg-slate-800 rounded-3xl transition">
                    <i class="fa-solid fa-globe w-5"></i>
                    <span>Markets</span>
                </a>
                <a onclick="navigateTo('portfolio')" class="flex items-center gap-3 px-4 py-4 rounded-3xl bg-emerald-500/10 text-emerald-400 font-medium">
                    <i class="fa-solid fa-briefcase w-5"></i>
                    <span>Portfolio</span>
                </a>
                <a onclick="navigateTo('watchlist')" class="flex items-center gap-3 px-4 py-4 hover:bg-slate-800 rounded-3xl transition">
                    <i class="fa-solid fa-star w-5"></i>
                    <span>Watchlist</span>
                </a>
                <a onclick="navigateTo('orders')" class="flex items-center gap-3 px-4 py-4 hover:bg-slate-800 rounded-3xl transition">
                    <i class="fa-solid fa-list-check w-5"></i>
                    <span>Orders</span>
                </a>
                <a onclick="navigateTo('analysis')" class="flex items-center gap-3 px-4 py-4 hover:bg-slate-800 rounded-3xl transition">
                    <i class="fa-solid fa-brain w-5"></i>
                    <span>AI Analysis</span>
                </a>
            </nav>

            <div class="mt-auto pt-8 border-t border-slate-700">
                <div onclick="exportPortfolio()" class="flex items-center justify-center gap-2 bg-slate-800 hover:bg-emerald-500 hover:text-black transition px-5 py-4 rounded-3xl cursor-pointer text-sm font-medium">
                    <i class="fa-solid fa-download"></i>
                    <span>Export CSV / Tax Report</span>
                </div>
            </div>
        </div>

        <!-- MAIN PORTFOLIO CONTENT -->
        <div class="flex-1 overflow-auto p-8">

            <div class="flex justify-between items-end mb-8">
                <div>
                    <h1 class="text-4xl font-bold">Your Portfolio</h1>
                    <p class="text-slate-400 mt-1">Real-time P&amp;L • Diversification • Performance curve</p>
                </div>
                
                <div class="flex items-center gap-4">
                    <div onclick="filterPortfolio('all')" id="filter-all" class="filter-btn active px-6 py-3 rounded-3xl text-sm font-medium cursor-pointer">All Holdings</div>
                    <div onclick="filterPortfolio('asx')" id="filter-asx" class="filter-btn px-6 py-3 rounded-3xl text-sm font-medium cursor-pointer">ASX Only</div>
                    <div onclick="filterPortfolio('crypto')" id="filter-crypto" class="filter-btn px-6 py-3 rounded-3xl text-sm font-medium cursor-pointer">Crypto</div>
                    <div onclick="filterPortfolio('us')" id="filter-us" class="filter-btn px-6 py-3 rounded-3xl text-sm font-medium cursor-pointer">US Stocks</div>
                </div>
            </div>

            <!-- PERFORMANCE CURVE -->
            <div class="bg-slate-900 rounded-3xl p-6 mb-8 border border-slate-700">
                <div class="flex justify-between mb-6">
                    <div class="font-semibold text-lg">Portfolio Performance</div>
                    <div class="flex gap-2 text-sm">
                        <button onclick="changePerformancePeriod(7)" class="perf-btn active px-5 py-2 rounded-3xl">7D</button>
                        <button onclick="changePerformancePeriod(30)" class="perf-btn px-5 py-2 rounded-3xl">30D</button>
                        <button onclick="changePerformancePeriod(90)" class="perf-btn px-5 py-2 rounded-3xl">90D</button>
                        <button onclick="changePerformancePeriod(365)" class="perf-btn px-5 py-2 rounded-3xl">1Y</button>
                        <button onclick="changePerformancePeriod('all')" class="perf-btn px-5 py-2 rounded-3xl">ALL</button>
                    </div>
                </div>
                <canvas id="performanceChart" class="w-full h-80"></canvas>
            </div>

            <div class="grid grid-cols-12 gap-8">

                <!-- HOLDINGS TABLE -->
                <div class="col-span-8 bg-slate-900 rounded-3xl p-6 border border-slate-700">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="font-semibold text-xl">Holdings • 7 positions</h2>
                        <div class="text-emerald-400 text-sm flex items-center gap-1 cursor-pointer" onclick="viewAllHoldings()">
                            View all <i class="fa-solid fa-arrow-right"></i>
                        </div>
                    </div>

                    <table class="w-full" id="holdings-table">
                        <thead>
                            <tr class="text-xs text-slate-400 border-b border-slate-700">
                                <th class="text-left py-4 font-medium">ASSET</th>
                                <th class="text-right py-4 font-medium">QTY</th>
                                <th class="text-right py-4 font-medium">AVG COST</th>
                                <th class="text-right py-4 font-medium">CURRENT</th>
                                <th class="text-right py-4 font-medium">VALUE</th>
                                <th class="text-right py-4 font-medium">P&amp;L</th>
                                <th class="text-right py-4 font-medium">% RETURN</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm divide-y divide-slate-700" id="holdings-body">
                            <!-- Populated by JS -->
                        </tbody>
                    </table>
                </div>

                <!-- ALLOCATION + STATS -->
                <div class="col-span-4 flex flex-col gap-6">

                    <!-- Pie Chart -->
                    <div class="bg-slate-900 rounded-3xl p-6 border border-slate-700 flex-1">
                        <div class="font-semibold mb-6">Asset Allocation</div>
                        <canvas id="allocationChart" class="w-full h-64"></canvas>
                    </div>

                    <!-- Key Metrics -->
                    <div class="bg-slate-900 rounded-3xl p-6 border border-slate-700">
                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <div class="text-xs text-slate-400">XIRR</div>
                                <div class="text-3xl font-semibold text-emerald-400">18.4%</div>
                                <div class="text-xs text-emerald-400">+4.2% this month</div>
                            </div>
                            <div>
                                <div class="text-xs text-slate-400">Diversification Score</div>
                                <div class="text-3xl font-semibold">92/100</div>
                                <div class="text-xs text-emerald-400">Excellent • Low concentration risk</div>
                            </div>
                            <div class="col-span-2 text-xs bg-slate-800 rounded-2xl p-4 flex items-center justify-between">
                                <span>Biggest winner</span>
                                <span class="text-emerald-400 font-medium">BTC • +42%</span>
                            </div>
                            <div class="col-span-2 text-xs bg-slate-800 rounded-2xl p-4 flex items-center justify-between">
                                <span>Biggest loser</span>
                                <span class="text-red-400 font-medium">CBA • -3.8%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Tailwind
        tailwind.config = { content: [] }

        // Fake portfolio holdings (matches your trade.html data)
        let holdings = [
            {
                symbol: "BHP.AX",
                name: "BHP Group",
                qty: 420,
                avgCost: 41.20,
                current: 43.82,
                value: 18404.40,
                pnl: 1104.40,
                pnlPct: 6.38,
                type: "asx"
            },
            {
                symbol: "CBA.AX",
                name: "Commonwealth Bank",
                qty: 85,
                avgCost: 148.10,
                current: 145.30,
                value: 12350.50,
                pnl: -238.00,
                pnlPct: -1.89,
                type: "asx"
            },
            {
                symbol: "BTC",
                name: "Bitcoin",
                qty: 0.12,
                avgCost: 52000,
                current: 64320,
                value: 7718.40,
                pnl: 1478.40,
                pnlPct: 23.72,
                type: "crypto"
            },
            {
                symbol: "AAPL",
                name: "Apple Inc.",
                qty: 28,
                avgCost: 210,
                current: 228.40,
                value: 6395.20,
                pnl: 514.40,
                pnlPct: 8.75,
                type: "us"
            },
            {
                symbol: "RIO.AX",
                name: "Rio Tinto",
                qty: 65,
                avgCost: 112,
                current: 118.90,
                value: 7728.50,
                pnl: 449.50,
                pnlPct: 6.17,
                type: "asx"
            },
            {
                symbol: "MQG.AX",
                name: "Macquarie Group",
                qty: 22,
                avgCost: 198,
                current: 212.80,
                value: 4681.60,
                pnl: 327.60,
                pnlPct: 7.52,
                type: "asx"
            },
            {
                symbol: "CSL.AX",
                name: "CSL Limited",
                qty: 12,
                avgCost: 305,
                current: 312.45,
                value: 3749.40,
                pnl: 89.40,
                pnlPct: 2.44,
                type: "asx"
            }
        ]

        function renderHoldings(filteredHoldings = holdings) {
            const tbody = document.getElementById('holdings-body')
            tbody.innerHTML = filteredHoldings.map(h => `
                <tr onclick="loadSymbolInChart('${h.symbol}')" class="hover:bg-slate-800 cursor-pointer transition">
                    <td class="py-5">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 bg-gradient-to-br ${h.type === 'crypto' ? 'from-orange-500 to-yellow-500' : h.type === 'us' ? 'from-blue-500 to-cyan-500' : 'from-emerald-500 to-teal-500'} rounded-2xl flex items-center justify-center text-white text-xs font-bold">${h.symbol.substring(0,3)}</div>
                            <div>
                                <div class="font-semibold">${h.symbol}</div>
                                <div class="text-xs text-slate-400">${h.name}</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-5 text-right font-medium">${h.qty}</td>
                    <td class="py-5 text-right font-mono">$${h.avgCost}</td>
                    <td class="py-5 text-right font-mono">$${h.current}</td>
                    <td class="py-5 text-right font-semibold">$${(h.value).toLocaleString('en-US')}</td>
                    <td class="py-5 text-right ${h.pnl > 0 ? 'text-emerald-400' : 'text-red-400'} font-medium">
                        ${h.pnl > 0 ? '+' : ''}$${Math.abs(h.pnl).toFixed(2)}
                    </td>
                    <td class="py-5 text-right ${h.pnlPct > 0 ? 'text-emerald-400' : 'text-red-400'} font-medium">
                        ${h.pnlPct > 0 ? '+' : ''}${h.pnlPct.toFixed(1)}%
                    </td>
                </tr>
            `).join('')
        }

        // Performance Line Chart (Portfolio vs ASX 200)
        let performanceChartInstance
        function initPerformanceChart(days = 30) {
            const ctx = document.getElementById('performanceChart')
            if (performanceChartInstance) performanceChartInstance.destroy()

            const labels = Array.from({length: days}, (_, i) => {
                const d = new Date()
                d.setDate(d.getDate() - (days - i))
                return d.toLocaleDateString('en-AU', {day:'numeric', month:'short'})
            })

            const portfolioData = Array.from({length: days}, (_, i) => 42000 + (i * 420) + Math.random() * 800)
            const benchmarkData = Array.from({length: days}, (_, i) => 7200 + (i * 45) + Math.random() * 120)

            performanceChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Your Portfolio',
                            data: portfolioData,
                            borderColor: '#22c55e',
                            tension: 0.3,
                            borderWidth: 3,
                            pointRadius: 0
                        },
                        {
                            label: 'ASX 200',
                            data: benchmarkData,
                            borderColor: '#64748b',
                            tension: 0.3,
                            borderWidth: 2,
                            pointRadius: 0
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: true, position: 'top', align: 'end' } },
                    scales: {
                        y: { grid: { color: '#334155' }, ticks: { color: '#64748b' } },
                        x: { grid: { color: '#334155' }, ticks: { color: '#64748b' } }
                    }
                }
            })
        }

        // Allocation Pie Chart
        let allocationChartInstance
        function initAllocationChart() {
            const ctx = document.getElementById('allocationChart')
            if (allocationChartInstance) allocationChartInstance.destroy()

            allocationChartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['ASX Equities', 'Crypto', 'US Stocks', 'Cash'],
                    datasets: [{
                        data: [62, 16, 13, 9],
                        backgroundColor: ['#10b981', '#f59e0b', '#3b82f6', '#64748b'],
                        borderColor: '#0f172a',
                        borderWidth: 4
                    }]
                },
                options: {
                    responsive: true,
                    cutout: '70%',
                    plugins: {
                        legend: { position: 'bottom', labels: { color: '#e2e8f0', boxWidth: 12, padding: 20, font: { size: 13 } } }
                    }
                }
            })
        }

        // Live total value updater
        function simulateLivePortfolio() {
            setInterval(() => {
                let value = parseFloat(document.getElementById('total-value').innerText.replace('$', '').replace(',', ''))
                value += (Math.random() * 120 - 40)
                document.getElementById('total-value').innerText = '$' + value.toFixed(2)

                // Randomly update one holding
                if (Math.random() > 0.6) {
                    holdings[0].current += (Math.random() * 1.2 - 0.5)
                    holdings[0].value = holdings[0].qty * holdings[0].current
                    holdings[0].pnl = holdings[0].value - (holdings[0].qty * holdings[0].avgCost)
                    holdings[0].pnlPct = (holdings[0].pnl / (holdings[0].qty * holdings[0].avgCost)) * 100
                    renderHoldings()
                }
            }, 3200)
        }

        function filterPortfolio(type) {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'))
            if (type === 'all') document.getElementById('filter-all').classList.add('active')
            else if (type === 'asx') document.getElementById('filter-asx').classList.add('active')
            else if (type === 'crypto') document.getElementById('filter-crypto').classList.add('active')
            else document.getElementById('filter-us').classList.add('active')

            let filtered = holdings
            if (type !== 'all') filtered = holdings.filter(h => h.type === type)
            renderHoldings(filtered)
        }

        function changePerformancePeriod(period) {
            document.querySelectorAll('.perf-btn').forEach(b => b.classList.remove('active'))
            event.target.classList.add('active')
            initPerformanceChart(typeof period === 'number' ? period : 365)
        }

        function loadSymbolInChart(symbol) {
            alert(`📈 Loading ${symbol} in full TradingView chart (opens trade.html automatically in real app)`)
            // In real SPA you would switch views or open trade.html with ?symbol=BHP.AX
            window.location.href = 'trade.html?symbol=' + symbol
        }

        function viewAllHoldings() {
            alert('🔥 Full detailed holdings view with sparklines and tax implications would load here.\n\nWant me to add sparklines + export next?')
        }

        function exportPortfolio() {
            alert('📤 Portfolio exported as CSV + Australian tax report (ready for ATO).')
        }

        function navigateTo(page) {
            if (page === 'dashboard') window.location.href = 'trade.html'
            else if (page === 'orders') alert('📋 Orders page coming next – say YES and I’ll drop it instantly!')
            else alert(`✅ ${page.toUpperCase()} page would load here.`)
        }

        function switchMarket() {
            alert('🌍 Market switched – portfolio now showing combined AU + US + Crypto')
            renderHoldings()
        }

        // INIT
        window.onload = function() {
            renderHoldings()
            initPerformanceChart(30)
            initAllocationChart()
            simulateLivePortfolio()

            console.log('%c✅ TradeArena Portfolio v2.0 loaded – Zerodha + Groww + TradingView level complete!', 'color:#22c55e; font-size:14px; font-weight:bold')
            
            // Supabase note for you
            console.log('%c💡 Next: Connect this to Supabase? Just give me your table names and I’ll add real fetch() calls.', 'color:#eab308')
        }
    </script>
</body>
</html>
